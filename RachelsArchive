  ============================================================ */
  --bg:#4E6E7E;       /* main background */
  --bg2:#3E5C6C;      /* darker sections */
  --bg3:#334E5C;      /* darkest sections */
  --light:#C8DDE0;    /* light section (process) */
  --white:#FFFFFF;
  --terra:#A2DBD6;    /* accent color */
  --terra2:#C8EDEA;   /* accent light */
  --muted:rgba(255,255,255,0.45);
  --border:rgba(255,255,255,0.14);
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--white);overflow-x:hidden;font-size:16px;line-height:1.7}
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:22px 48px}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:300;font-style:italic;color:var(--white);text-decoration:none;letter-spacing:0.04em}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.55);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--white)}
.hero{position:relative;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:var(--bg2)}
.hero-video-wrap{position:absolute;inset:0;z-index:0;overflow:hidden}
.hero-video-wrap video{width:100%;height:100%;object-fit:cover;filter:brightness(0.5) saturate(0.65) hue-rotate(190deg)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(62,92,108,0.45) 0%,rgba(51,78,92,0.55) 100%);z-index:1}
.letters-field{position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden}
.ltr{position:absolute;font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,8vw,110px);color:rgba(255,255,255,0.07);user-select:none;animation:floatL 18s ease-in-out infinite}
.ltr:nth-child(1){top:8%;left:4%}.ltr:nth-child(2){top:12%;left:13%;animation-delay:.4s}.ltr:nth-child(3){top:7%;left:22%;animation-delay:.8s}.ltr:nth-child(4){top:14%;left:31%;animation-delay:1.2s}.ltr:nth-child(5){top:9%;left:40%;animation-delay:1.6s}.ltr:nth-child(6){top:13%;right:38%;animation-delay:2s}.ltr:nth-child(7){top:8%;right:26%;animation-delay:2.4s}.ltr:nth-child(8){top:13%;right:16%;animation-delay:2.8s}.ltr:nth-child(9){top:8%;right:7%;animation-delay:3.2s}.ltr:nth-child(10){top:18%;right:2%;animation-delay:3.6s}
@keyframes floatL{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
.hero-center{position:relative;z-index:3;text-align:center;padding:0 24px}
.hero-eyebrow{font-size:11px;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:var(--terra2);margin-bottom:28px;display:block}
.hero-im{font-family:'DM Sans',sans-serif;font-size:14px;font-weight:300;color:rgba(255,255,255,0.45);letter-spacing:0.06em;margin-bottom:-8px}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(80px,14vw,200px);line-height:0.9;color:var(--white);letter-spacing:0.02em;display:block}
.hero-title .accent{color:var(--terra)}
.hero-sub{font-family:'Cormorant Garamond',serif;font-size:clamp(18px,2.5vw,26px);font-weight:300;font-style:italic;color:rgba(255,255,255,0.7);margin:20px 0 36px;letter-spacing:0.02em}
.hero-cta{display:flex;gap:20px;justify-content:center;align-items:center;flex-wrap:wrap}
.btn-dark{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.15);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.3);color:var(--white);font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;padding:14px 32px;text-decoration:none;transition:background .2s,transform .15s}
.btn-dark:hover{background:rgba(255,255,255,0.25);transform:translateY(-2px)}
.btn-ghost{font-size:12px;font-weight:400;color:rgba(255,255,255,0.5);text-decoration:none;letter-spacing:0.08em;text-transform:uppercase;border-bottom:0.5px solid rgba(255,255,255,0.25);padding-bottom:2px;transition:color .2s}
.btn-ghost:hover{color:var(--white)}
.hero-scroll{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:8px}
.scroll-line{width:0.5px;height:48px;background:linear-gradient(to bottom,rgba(255,255,255,0.5),transparent);animation:scrollpulse 2s ease-in-out infinite}
.scroll-label{font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.35)}
@keyframes scrollpulse{0%,100%{opacity:0.4}50%{opacity:1}}
.ticker{background:var(--bg3);overflow:hidden;padding:13px 0;white-space:nowrap;border-top:0.5px solid rgba(255,255,255,0.1);border-bottom:0.5px solid rgba(255,255,255,0.1)}
.ticker-inner{display:inline-flex;animation:tick 24s linear infinite}
.ticker-item{font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.7);padding:0 28px}
.ticker-dot{color:var(--terra);font-size:14px;vertical-align:middle}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
section{padding:100px 64px}
.s-label{font-size:11px;font-weight:500;letter-spacing:0.16em;text-transform:uppercase;color:var(--terra);margin-bottom:12px;display:block}
.s-head{font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,6vw,80px);line-height:0.95;color:var(--white);margin-bottom:8px;letter-spacing:0.02em}
.s-head em{color:var(--terra);font-style:normal}
.about{background:var(--bg2)}
.about-grid{display:grid;grid-template-columns:1fr 1.5fr;gap:80px;max-width:1200px;margin:0 auto;align-items:start}
.about-body{font-size:16px;color:rgba(255,255,255,0.65);line-height:1.85;margin-bottom:20px}
.about-body strong{color:var(--white);font-weight:500}
.skills{display:flex;flex-wrap:wrap;gap:8px;margin-top:32px}
.skill{font-size:11px;letter-spacing:0.07em;padding:7px 16px;border:0.5px solid var(--border);color:rgba(255,255,255,0.5);transition:border-color .2s,color .2s;cursor:default}
.skill:hover{border-color:var(--terra);color:var(--terra2)}
.industries{margin-top:40px;padding-top:32px;border-top:0.5px solid var(--border)}
.ind-label{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:14px}
.ind-pills{display:flex;flex-wrap:wrap;gap:8px}
.ind-pill{font-size:12px;font-weight:500;padding:6px 16px;background:rgba(162,219,214,0.12);color:var(--terra2);letter-spacing:0.02em;border:0.5px solid rgba(162,219,214,0.25)}
.projects{background:var(--bg);padding-bottom:120px}
.projects-intro{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:64px;gap:40px;flex-wrap:wrap}
.project-list{display:flex;flex-direction:column;gap:1px}
.project-item{display:grid;grid-template-columns:72px 1fr auto;align-items:center;gap:32px;padding:28px 40px;background:var(--bg2);text-decoration:none;color:inherit;border-left:2px solid transparent;transition:background .25s,border-color .25s}
.project-item:hover{background:var(--bg3);border-color:var(--terra)}
.project-item:hover .pi-arrow{transform:translate(4px,-4px);color:var(--terra2)}
.project-item:hover .pi-num{color:rgba(255,255,255,0.2)}
.pi-num{font-family:'Bebas Neue',sans-serif;font-size:36px;color:rgba(255,255,255,0.1);line-height:1;transition:color .25s}
.pi-cat{font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:6px}
.pi-title{font-family:'Cormorant Garamond',serif;font-size:clamp(20px,2.5vw,28px);font-weight:300;color:var(--white);line-height:1.2;margin-bottom:8px}
.pi-desc{font-size:13px;color:rgba(255,255,255,0.45);line-height:1.6}
.pi-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
.pi-tag{font-size:10px;letter-spacing:0.05em;padding:3px 10px;border:0.5px solid var(--border);color:rgba(255,255,255,0.35)}
.pi-arrow{font-size:22px;color:rgba(255,255,255,0.2);transition:transform .25s,color .25s;flex-shrink:0}
.pi-featured{background:rgba(162,219,214,0.1);border-left:2px solid var(--terra)}
.pi-featured:hover{background:rgba(162,219,214,0.18)}
.pi-featured .pi-num{color:rgba(162,219,214,0.2)}
.process{background:var(--light);padding:100px 64px}
.process .s-label{color:var(--bg3)}
.process .s-head{color:var(--bg3)}
.process .s-head em{color:var(--bg)}
.process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:60px;border-top:0.5px solid rgba(51,78,92,0.18)}
.p-step{padding:36px 32px 36px 0;border-right:0.5px solid rgba(51,78,92,0.12)}
.p-step:last-child{border-right:none;padding-right:0;padding-left:32px}
.p-step:not(:first-child):not(:last-child){padding-left:32px}
.p-num{font-family:'Bebas Neue',sans-serif;font-size:64px;color:rgba(51,78,92,0.1);line-height:1;margin-bottom:12px}
.p-title{font-size:14px;font-weight:500;color:var(--bg3);margin-bottom:10px;letter-spacing:0.03em}
.p-desc{font-size:13px;color:rgba(51,78,92,0.6);line-height:1.7}
.contact{background:var(--bg3);text-align:center;padding:120px 48px}
.contact-big{font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,10vw,130px);line-height:0.9;color:var(--white);letter-spacing:0.02em;margin:24px 0}
