.contact-sub{font-size:15px;color:rgba(255,255,255,0.5);max-width:480px;margin:0 auto 48px;line-height:1.75}
.contact-email{display:block;font-family:'Cormorant Garamond',serif;font-size:clamp(22px,3vw,36px);font-weight:300;font-style:italic;color:var(--terra2);text-decoration:none;margin-bottom:40px;transition:opacity .2s}
.contact-email:hover{opacity:.7}
.contact-links{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
.c-link{font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.45);text-decoration:none;border-bottom:0.5px solid var(--border);padding-bottom:2px;transition:color .2s,border-color .2s}
.c-link:hover{color:var(--white);border-color:rgba(255,255,255,0.5)}
footer{background:var(--bg3);padding:24px 48px;display:flex;justify-content:space-between;align-items:center;border-top:0.5px solid rgba(255,255,255,0.08)}
.f-name{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:300;font-style:italic;color:rgba(255,255,255,0.3)}
.f-right{font-size:11px;color:rgba(255,255,255,0.2);letter-spacing:0.06em}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:none}
@media(max-width:900px){
  nav{padding:16px 24px}.nav-links{display:none}
  section{padding:72px 24px}.about-grid{grid-template-columns:1fr;gap:40px}
  .project-item{grid-template-columns:48px 1fr 24px;gap:16px;padding:20px}
  .process-steps{grid-template-columns:1fr 1fr}
  .p-step{padding:24px;border-right:none;border-bottom:0.5px solid rgba(51,78,92,0.12)}
  footer{flex-direction:column;gap:8px;text-align:center}.process{padding:72px 24px}
}
</style>
